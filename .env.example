# Postgres local (docker-compose)
DATABASE_URL=postgresql://traveltogether:traveltogether@localhost:5432/traveltogether

# URL da API consumida pelo web (dev local)
TRAVELTOGETHER_API_URL=http://localhost:8000

# Upload de imagens de capa (Cloudflare R2 / S3-compatible)
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=traveltogether-covers
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_BASE_URL=https://cdn.example.com/traveltogether-covers
# COVER_IMAGE_MAX_BYTES=5242880

# Auth.js — gerar com: openssl rand -base64 32
# AUTH_SECRET=

# Google OAuth — criar em console.cloud.google.com > APIs > Credenciais
# 🔴 HITL: provisionar no Google Cloud Console e registrar secrets no Coolify
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Resend — provedor de e-mail transacional (OTP + convites)
# 🔴 HITL: criar conta em resend.com, verificar domínio, gerar API key
# RESEND_API_KEY=
