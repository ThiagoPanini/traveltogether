{
  "$meta": {
    "name": "TravelManager — Noturno",
    "version": "1.0.0",
    "description": "Fonte viva dos tokens nomeados de Noturno, originados no protótipo congelado do Claude Design e mantidos pelo contrato docs/design.",
    "locale": "pt-BR",
    "fonts": ["Saira Condensed", "Public Sans", "Spline Sans Mono"]
  },
  "color": {
    "background": {
      "root": { "value": "#0f171e", "use": "raiz da página (html/body), nível mais profundo" },
      "canvas": {
        "value": "#14202b",
        "use": "tela principal do app; também cor de texto sobre accent"
      },
      "inset": { "value": "#101920", "use": "painel do mapa (superfície recuada)" },
      "surface": { "value": "#1a2530", "use": "cartões e superfícies elevadas" },
      "surfaceBar": { "value": "#1e2a35", "use": "barra inferior (switcher)" },
      "fillSubtle": {
        "value": "#243240",
        "use": "inputs, trilha de progresso, estado de toggle ativo"
      },
      "fillAccent": {
        "value": "#33231e",
        "use": "cartão de rota selecionada (tinta quente do accent)"
      }
    },
    "line": {
      "default": { "value": "#2b3945", "use": "hairline / divisores primários (1px)" },
      "muted": { "value": "#33424f", "use": "borda da switcher, cartão de rota inativo" },
      "dashed": { "value": "#3a4a57", "use": "bordas tracejadas, borda de input" },
      "strong": { "value": "#4a5a66", "use": "contorno de botão fantasma, anel de avatar" },
      "faint": { "value": "#5a6570", "use": "ícones e dots apagados" }
    },
    "text": {
      "bright": { "value": "#f4ecda", "use": "títulos mais claros (creme)" },
      "body": { "value": "#e9e1cf", "use": "corpo primário (off-white quente)" },
      "muted": { "value": "#9aa7b1", "use": "secundário, parágrafos de apoio" },
      "mono": { "value": "#8a96a0", "use": "texto mono apagado" },
      "faint": { "value": "#7d8a93", "use": "rótulos e captions mono" },
      "faintest": { "value": "#6b7680", "use": "texto mínimo" }
    },
    "accent": {
      "default": { "value": "#df6a4d", "use": "marca, CTA, estado ativo, destaque" },
      "alert": { "value": "#e8856e", "use": "variante de alerta (ttl < 60s)" },
      "onAccent": { "value": "#14202b", "use": "texto/ícone sobre superfície accent" }
    },
    "semantic": {
      "success": { "value": "#4fa58e", "use": "concluído / status \"definido\"" },
      "warning": { "value": "#e0a948", "use": "pendente / status \"em aberto\"" },
      "successBorder": { "value": "rgba(79,165,142,0.45)" },
      "warningBorder": { "value": "rgba(224,169,72,0.45)" },
      "accentBorder": { "value": "rgba(223,106,77,0.45)" }
    },
    "selection": { "background": "#df6a4d", "text": "#0f171e" }
  },
  "typography": {
    "families": {
      "display": {
        "stack": "'Saira Condensed', sans-serif",
        "weights": [500, 600, 700],
        "transform": "uppercase",
        "tracking": "0.03em–0.06em",
        "lineHeight": "0.85–0.9",
        "use": "títulos, números grandes, botões, chips, códigos IATA grandes"
      },
      "body": {
        "stack": "'Public Sans', sans-serif",
        "weights": [400, 500, 600],
        "transform": "none",
        "lineHeight": "1.45–1.55",
        "use": "parágrafos e corpo de texto (13–17px)"
      },
      "mono": {
        "stack": "'Spline Sans Mono', monospace",
        "weights": [400, 500],
        "transform": "uppercase",
        "tracking": "0.06em–0.16em",
        "use": "rótulos, metadados, captions, códigos (9–13px)"
      }
    },
    "scale": [
      { "role": "hero", "family": "display", "size": "74px", "weight": 700 },
      { "role": "h1", "family": "display", "size": "56px", "weight": 700 },
      { "role": "h2", "family": "display", "size": "34–42px", "weight": 700 },
      { "role": "cardTitle", "family": "display", "size": "18–22px", "weight": 600 },
      { "role": "bodyLg", "family": "body", "size": "17px", "weight": 400 },
      { "role": "body", "family": "body", "size": "14–16px", "weight": 400 },
      { "role": "bodySm", "family": "body", "size": "13px", "weight": 500 },
      { "role": "monoLabel", "family": "mono", "size": "10–13px", "weight": 500 },
      { "role": "monoCaption", "family": "mono", "size": "9px", "weight": 400 }
    ]
  },
  "radius": {
    "circle": "50%",
    "pill": "99px",
    "lg": "12px",
    "md": "10px",
    "card": "9px",
    "sm": "7px",
    "btn": "7px",
    "bar": "2px"
  },
  "border": {
    "hairline": "1px",
    "outline": "1.5px",
    "accentEdge": "3px"
  },
  "layout": {
    "pageGutter": "40px",
    "maxWidthWide": "1040px",
    "maxWidthPanel": "1000px",
    "heroMax": "720px",
    "loginCard": "400px",
    "mapPanelHeight": "460px"
  },
  "shadow": {
    "switcher": "0 8px 26px rgba(0,0,0,0.4)"
  }
}
