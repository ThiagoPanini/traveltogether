{
  "name": "traveltogether",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev:web": "pnpm --filter @traveltogether/web dev",
    "build:web": "pnpm --filter @traveltogether/web build",
    "typecheck:web": "pnpm --filter @traveltogether/web typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "lefthook": "^1.10.0"
  }
}
